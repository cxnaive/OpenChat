package com.example.messageservice.util;

import com.google.common.io.ByteArrayDataInput;
import com.google.common.io.ByteArrayDataOutput;
import com.google.common.io.ByteStreams;
import org.bukkit.Bukkit;
import org.bukkit.entity.Player;
import org.bukkit.plugin.java.JavaPlugin;

import java.io.*;
import java.util.ArrayList;
import java.util.List;
import java.util.Optional;

/**
 * BungeeCord/Velocity 跨服工具类
 * 完全移植自 PlayerChat 的 BcUtil
 */
public class BcUtil {

    /**
     * BungeeCord 标准通道
     */
    public static final String BUNGEE_CORD_CHANNEL = "BungeeCord";

    /**
     * 调试模式开关
     */
    private static boolean debugEnabled = false;

    /**
     * 设置调试模式
     * @param enabled 是否启用调试模式
     */
    public static void setDebugEnabled(boolean enabled) {
        debugEnabled = enabled;
    }

    /**
     * 检查调试模式是否启用
     * @return 是否启用调试模式
     */
    public static boolean isDebugEnabled() {
        return debugEnabled;
    }

    /**
     * 消息参数类
     */
    public static class BcMessageParam implements Serializable {
        private static final long serialVersionUID = 1L;

        private String type;
        private String playerName;
        private String message;
        private Long timestamp;
        private String serverName;

        public BcMessageParam() {
        }

        public String getType() {
            return type;
        }

        public void setType(String type) {
            this.type = type;
        }

        public String getPlayerName() {
            return playerName;
        }

        public void setPlayerName(String playerName) {
            this.playerName = playerName;
        }

        public String getMessage() {
            return message;
        }

        public void setMessage(String message) {
            this.message = message;
        }

        public Long getTimestamp() {
            return timestamp;
        }

        public void setTimestamp(Long timestamp) {
            this.timestamp = timestamp;
        }

        public String getServerName() {
            return serverName;
        }

        public void setServerName(String serverName) {
            this.serverName = serverName;
        }
    }

    /**
     * 发送参数到 BungeeCord/Velocity (Forward 格式)
     * 这是 PlayerChat 使用的标准方法
     *
     * @param player 玩家
     * @param param  消息参数
     */
    public static void sendParamForward(Player player, BcMessageParam param) {
        sendParamForwardToServer(player, "ALL", param);
    }

    /**
     * 发送参数到指定服务器 (Forward 格式)
     *
     * @param player 玩家
     * @param targetServer 目标服务器名称（"ALL" 表示所有服务器）
     * @param param  消息参数
     */
    public static void sendParamForwardToServer(Player player, String targetServer, BcMessageParam param) {
        try {
            byte[] paramBytes = serialize(param);

            ByteArrayDataOutput out = ByteStreams.newDataOutput();
            out.writeUTF("Forward");
            out.writeUTF(targetServer);
            out.writeUTF("PlayerChat");
            out.writeShort(paramBytes.length);
            out.write(paramBytes);

            player.sendPluginMessage(player.getServer().getPluginManager().getPlugin("MessageService"), 
                    BUNGEE_CORD_CHANNEL, out.toByteArray());
        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    /**
     * 从 Forward 消息中解析参数
     * 支持两种格式：
     * 1. 标准 BungeeCord Forward 格式
     * 2. Velocity 直接转发格式（已解包）
     *
     * @param message 消息字节数组
     * @return 解析后的参数
     */
    public static Optional<BcMessageParam> getParamByForward(byte[] message) {
        try {
            ByteArrayDataInput input = ByteStreams.newDataInput(message);
            String subChannel = input.readUTF();

            // 情况1：Velocity 直接转发，子通道是 PlayerChat
            // 说明 Velocity 已经解包了 Forward，剩余数据就是序列化的 BcMessageParam
            if ("PlayerChat".equals(subChannel)) {
                // 打印调试信息（仅在调试模式下）
                if (debugEnabled) {
                    System.err.println("[BcUtil] 收到 PlayerChat 消息，总长度: " + message.length);
                    for (int i = 0; i < Math.min(20, message.length); i++) {
                        System.err.printf("[BcUtil] 字节[%d]: 0x%02X (%d)\n", i, message[i] & 0xFF, message[i] & 0xFF);
                    }
                }
                
                // Velocity 转发的格式：
                // 字节0-1: UTF长度前缀
                // 字节2-11: "PlayerChat"
                // 字节12-13: 额外的字符串（可能是 Velocity 添加的元数据）
                // 字节14+: 序列化数据（从 0xACED 开始）
                
                // 从字节14开始读取序列化数据（0xACED 是 Java 序列化魔数）
                if (message.length > 14) {
                    int skipBytes = 14;
                    byte[] actualData = new byte[message.length - skipBytes];
                    System.arraycopy(message, skipBytes, actualData, 0, actualData.length);
                    if (debugEnabled) {
                        System.err.println("[BcUtil] 跳过 " + skipBytes + " 字节，剩余数据长度: " + actualData.length);
                        if (actualData.length > 0) {
                            System.err.printf("[BcUtil] 实际数据前4字节: 0x%02X%02X%02X%02X\n", 
                                actualData[0] & 0xFF, actualData[1] & 0xFF, actualData[2] & 0xFF, actualData[3] & 0xFF);
                        }
                    }
                    BcMessageParam param = deserialize(actualData, BcMessageParam.class);
                    return Optional.ofNullable(param);
                }
                
                if (debugEnabled) {
                    System.err.println("[BcUtil] 消息长度不足，无法解析");
                }
                return Optional.empty();
            }

            // 情况2：标准 Forward 格式
            if (!"Forward".equals(subChannel)) {
                return Optional.empty();
            }

            // 读取 Forward 头
            String target = input.readUTF();  // 目标服务器
            String channel = input.readUTF();  // 子通道
            short length = input.readShort();  // 数据长度

            // 读取实际数据
            byte[] data = new byte[length];
            input.readFully(data);

            // 反序列化参数
            BcMessageParam param = deserialize(data, BcMessageParam.class);
            return Optional.ofNullable(param);
        } catch (Exception e) {
            e.printStackTrace();
            return Optional.empty();
        }
    }

    /**
     * 获取在线玩家列表
     *
     * @param message 消息字节数组
     * @return 玩家列表
     */
    public static List<String> getPlayerList(byte[] message) {
        List<String> playerList = new ArrayList<>();
        try {
            ByteArrayDataInput input = ByteStreams.newDataInput(message);
            String subChannel = input.readUTF();

            if (!"PlayerList".equals(subChannel)) {
                return playerList;
            }

            String server = input.readUTF();  // 服务器名
            String playerString = input.readUTF();  // 玩家名字符串

            if (playerString != null && !playerString.isEmpty()) {
                for (String playerName : playerString.split(", ")) {
                    if (!playerName.isEmpty()) {
                        playerList.add(playerName);
                    }
                }
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
        return playerList;
    }

    /**
     * 请求玩家列表
     *
     * @param plugin 插件实例
     */
    public static void requestPlayerList(JavaPlugin plugin) {
        Player player = Bukkit.getOnlinePlayers().stream().findFirst().orElse(null);
        if (player == null) {
            return;
        }

        ByteArrayDataOutput out = ByteStreams.newDataOutput();
        out.writeUTF("PlayerList");  // BungeeCord 指令
        out.writeUTF("ALL");  // 请求所有服务器的玩家

        player.sendPluginMessage(plugin, BUNGEE_CORD_CHANNEL, out.toByteArray());
    }

    /**
     * 序列化对象
     */
    private static byte[] serialize(Object obj) throws IOException {
        ByteArrayOutputStream bos = new ByteArrayOutputStream();
        ObjectOutputStream oos = new ObjectOutputStream(bos);
        oos.writeObject(obj);
        oos.close();
        return bos.toByteArray();
    }

    /**
     * 反序列化对象
     */
    @SuppressWarnings("unchecked")
    private static <T> T deserialize(byte[] data, Class<T> clazz) throws IOException, ClassNotFoundException {
        ByteArrayInputStream bis = new ByteArrayInputStream(data);
        ObjectInputStream ois = new ObjectInputStream(bis);
        T obj = (T) ois.readObject();
        ois.close();
        return obj;
    }
}
